# ============================================================
# ALGORA GROWTH AGENT — конфигурация
# Скопируй в .env и заполни своими данными
# ============================================================

# --- Telegram userbot ---
# Получить на https://my.telegram.org → API development tools
TG_API_ID=12345678
TG_API_HASH=abcdef1234567890abcdef1234567890
TG_PHONE=+7XXXXXXXXXX
TG_SESSION_NAME=growth_agent   # имя файла сессии (без расширения)

# --- Личность агента ---
AGENT_NAME=Максим              # Имя, от которого пишет агент в чатах
CHANNEL_LINK=@my_channel       # Ссылка на канал, который продвигаем

# --- Claude API (direct) ---
# Агент вызывает Claude напрямую (без NATS AI Proxy)
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-haiku-4-5-20251001

# --- PostgreSQL ---
# Хранит список чатов, лимиты, историю сообщений
POSTGRES_DSN=postgresql://growth_user:password@10.0.0.2:5432/algora_growth

# --- Лимиты поведения (опционально) ---
MAX_MESSAGES_PER_DAY=3         # макс. сообщений в одном чате за день
MIN_INTERVAL_SEC=3600          # мин. пауза между ответами в одном чате (сек)

# --- Ключевые слова для фильтра сообщений ---
# Через запятую. Агент реагирует только на сообщения, содержащие эти слова.
# Если не задать — используются дефолтные (WB/Ozon/маркетплейсы).
# Пример для другой ниши: недвижимость, аренда, ипотека, застройщик, квартира
RELEVANCE_KEYWORDS=
